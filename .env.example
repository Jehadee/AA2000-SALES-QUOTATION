# Backend API (required for production)
VITE_API_BASE_URL=https://your-api-host.com
VITE_API_BASE_PATH=/api

# Optional: override add-customer endpoint path if different on your server
# VITE_ADD_CUSTOMER_PATH=/customers/add/customer

# Optional: override products endpoint path if different on your server
# VITE_PRODUCTS_PATH=/api/get/products

# Optional: suppliers list (Sequelize Supplier: sup_ID, sup_storeName). Default: /suppliers/get/suppliers
# Fallback if empty: /products/get/suppliers
# VITE_SUPPLIERS_PATH=/suppliers/get/suppliers

# Optional: estimation inbox endpoints (ProductRoute)
# List endpoint should return { files: ["name1.pdf", ...] } or array of names.
# VITE_ESTIMATION_LIST_PATH=/products/list/estimationFiles
# Template endpoint for opening a file by name.
# Use {filename} placeholder for interpolation.
# VITE_ESTIMATION_FILE_PATH_TEMPLATE=/products/get/estimationFile/{filename}

# Portal launch encryption (must match appendSessionToUrl.ts / aa2000-portal)
# 64 hex chars (32 bytes) OR standard Base64 decoding to exactly 32 bytes.
# If unset: `vite dev` uses SHA-256(UTF-8 "aa2000-portal-launch-dev-v1"); production builds must set this for __launch/__actor.
# VITE_LAUNCH_AES_KEY=
# Optional legacy: AES-GCM IV||ciphertext+tag with key = SHA-256(this secret)
# VITE_LAUNCH_TOKEN_SECRET=
# VITE_LAUNCH_TOKEN_ENCRYPTION=
# Optional auth debug logs in browser console (safe metadata only, no raw token values)
# VITE_AUTH_DEBUG=false

# Gemini API key (required for AI assistant; set in Vercel as GEMINI_API_KEY)
# GEMINI_API_KEY=your_gemini_api_key

# Ally Virtual Webhook (webhook sender -> this app)
# Set this in Ally Virtual when configuring the webhook, and also in Vercel Environment Variables.
# The webhook validates one of these headers (in priority order):
#   x-ally-webhook-secret, x-ally-virtual-secret, x-webhook-secret, x-ally-webhook-token, authorization (Bearer ...)
ALLY_WEBHOOK_SECRET=

# Storage for incoming Ally Virtual opportunities (serverless webhook persistence)
# Recommended: Upstash Redis (set these in Vercel Environment Variables)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
