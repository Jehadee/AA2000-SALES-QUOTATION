# Backend API (required for production)
VITE_API_BASE_URL=https://your-api-host.com
VITE_API_BASE_PATH=/api

# Optional: override add-customer endpoint path if different on your server
# VITE_ADD_CUSTOMER_PATH=/customers/add/customer

# Optional: override products endpoint path if different on your server
# VITE_PRODUCTS_PATH=/api/get/products
# Optional: override add-product endpoint path if different on your server
# VITE_ADD_PRODUCT_PATH=/products/add/product
# Optional: override delete-product endpoint path. Supports either:
#   /products/delete/product/{id}  OR  /products/delete/product
# VITE_DELETE_PRODUCT_PATH=/products/delete/product/{id}

# Optional: suppliers list (Sequelize Supplier: sup_ID, sup_storeName). Default: /suppliers/get/suppliers
# Fallback if empty: /products/get/suppliers
# VITE_SUPPLIERS_PATH=/suppliers/get/suppliers

# Optional: PDF quotation logo image (GET, returns image/jpeg). Default path:
# VITE_QUOTATION_LOGO_PATH=/service/quotation/get/quotation-logo
# Optional: upload endpoint for quotation logo (multipart/form-data, field name: file)
# VITE_UPLOAD_QUOTATION_LOGO_PATH=/service/quotation/post/upload/quotation-logo

# Optional: estimation inbox (defaults under /service/quotation/get/)
# VITE_ESTIMATION_LIST_PATH=/service/quotation/get/list/estimationFiles
# VITE_ESTIMATION_FILE_PATH_TEMPLATE=/service/quotation/get/get/estimationFile/{filename}
# List should return JSON { files: ["name1.pdf", ...] } or a plain array of names.
# DOCX preview (optional): defaults from file template → .../get/preview/estimationFile/{filename}
# VITE_ESTIMATION_PREVIEW_PATH_TEMPLATE=/service/quotation/get/preview/estimationFile/{filename}


# Gemini API key (required for AI assistant; set in Vercel as GEMINI_API_KEY)
# GEMINI_API_KEY=your_gemini_api_key

# Ally Virtual Webhook (webhook sender -> this app)
# Set this in Ally Virtual when configuring the webhook, and also in Vercel Environment Variables.
# The webhook validates one of these headers (in priority order):
#   x-ally-webhook-secret, x-ally-virtual-secret, x-webhook-secret, x-ally-webhook-token, authorization (Bearer ...)
ALLY_WEBHOOK_SECRET=

# Storage for incoming Ally Virtual opportunities (serverless webhook persistence)
# Recommended: Upstash Redis (set these in Vercel Environment Variables)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
